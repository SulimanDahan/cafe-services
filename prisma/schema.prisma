generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model UserSession {
  id         String   @id @default(uuid())
  userId     String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  expires_at DateTime
  user       User     @relation(fields: [userId], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  title      String
  message    String
  read       Boolean  @default(false)
  created_at DateTime @default(now())
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique
  password     String
  is_admin     Boolean       @default(false)
  is_disable   Boolean       @default(false)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @default(now()) @updatedAt
  userSessions UserSession[]
}

model Room {
  id           String        @id @default(uuid())
  name         String        @unique
  is_disable   Boolean       @default(false)
  qr_code      String        @unique
  created_at   DateTime      @default(now())
  updated_at   DateTime      @default(now()) @updatedAt
  reservations Reservation[]
}

model ItemGroup {
  id         String   @id @default(uuid())
  name       String   @unique
  is_disable Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  items      Item[]
}

model Item {
  id         String    @id @default(uuid())
  name       String    @unique
  price      Decimal   @default(0)
  group_id   String
  is_disable Boolean   @default(false)
  image      String?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  group      ItemGroup @relation(fields: [group_id], references: [id])
  orders     Order[]
}

model Reservation {
  id            String          @id @default(uuid())
  number        Int             @unique @default(autoincrement())
  date_time     DateTime        @default(now())
  client_name   String
  phone         String
  room_id       String
  order_passkey Int             @unique
  accepted      Boolean         @default(false)
  activated     Boolean         @default(false)
  completed     Boolean         @default(false)
  rejected      Boolean         @default(false)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @default(now()) @updatedAt
  orders        Order[]
  room          Room            @relation(fields: [room_id], references: [id])
  clientReports clientReports[]
}

model Order {
  id             String      @id @default(uuid())
  reservation_id String
  item_id        String
  item_price     Decimal     @default(0)
  quantity       Int         @default(1)
  notes          String?
  accepted       Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @default(now()) @updatedAt
  item           Item        @relation(fields: [item_id], references: [id])
  reservation    Reservation @relation(fields: [reservation_id], references: [id])
}

model Settings {
  id                                 String   @id @default(uuid())
  currency_name                      String   @default("YER")
  notification_threshold             Int      @default(100)
  app_lang                           String   @default("ar")
  per_page                           Int      @default(25)
  session_expiry_minutes             Int      @default(60)
  client_session_expiry_minutes      Int      @default(360)
  created_at                         DateTime @default(now())
  updated_at                         DateTime @default(now()) @updatedAt
  force_client_order_session_passKey Boolean  @default(false)
  auto_accept_orders                 Boolean  @default(false)
}

model News {
  id         String   @id @default(uuid())
  news_text  String
  start_date DateTime @default(now())
  end_date   DateTime @default(now())
  is_disable Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model clientReports {
  id             String      @id @default(uuid())
  message_text   String
  is_read        Boolean     @default(false)
  reservation_id String
  created_at     DateTime    @default(now())
  updated_at     DateTime    @default(now()) @updatedAt
  reservation    Reservation @relation(fields: [reservation_id], references: [id])
}
